  m_Script: {fileID: 11500000, guid: 6583a8c65acc7c1ea0da6a34a63afcc0, type: 3}
  m_Name:
  m_EditorClassIdentifier:
  spikerBubble: {fileID: 49}
  setterBubble: {fileID: 47}
  winIntroSetter:
    dialogueOptions: []
  winIntroSpiker:
    dialogueOptions: []
  winIntrosGenericSetter: []
  winIntroGenericSpiker: []
  prepSetter:
  - I’ll pretend this was a team decision.
  - You keep flying, I’ll keep fixing
  - Fine. Let’s break the rules a bit.
  - Lets THINK this time.
  - They like patterns. Let’s break ’em.
  - We control the pace, we control the match.
  - If they can’t read us they can’t stop us.
  prepSpiker:
  - Oooh this one's spicy!
  - Okay okay okay—hear me out. We go max power, no mercy.
  - Do you think this’ll help me break the sound barrier?
  - Whatever gets me more air time. I want to live up there.
  - Ooh, nasty!
  - This’ll catch ’em slippin’.
  - I want all the power.
  outroSetter:
    dialogueOptions: []
  outroSpiker:
    dialogueOptions: []
  outroSpikerGeneric: []
  outroSetterGeneric: []
--- !u!114 &523
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 41}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: ab8fa7af98bc5f94e481413712cb5f27, type: 3}
  m_Name:
  m_EditorClassIdentifier:
  dialogueManager: {fileID: 536}
  poses:
  - {fileID: 516}
  - {fileID: 527}
  dialogue: {fileID: 503}
  stats: {fileID: 510}
  nextButton: {fileID: 147}
  skipButton: {fileID: 120}
  StatChartUI: {fileID: 193}
  statChart: {fileID: 520}
  techniques:
  - myTechnique: {fileID: 11400000, guid: ed5249f8890778841a299da4c518846a, type: 2}
    title: Counter Read
    description: Huge block boost on the opponent’s second touch.
    flavourText: “I know where you’re going.”
    sprite: {fileID: 21300000, guid: 3d6d0af2ec9315242a1526d07850d8e5, type: 2}
  - myTechnique: {fileID: 11400000, guid: ebae62cc48c434841884ec2ad1a97231, type: 2}
    title: Perfect Parry
    description: Increased chance of perfect digs.
    flavourText: “Reflexes? No. Instinct.”
    sprite: {fileID: 21300000, guid: eaecd4490c6c8154dac40f3fcfaf180d, type: 2}
  - myTechnique: {fileID: 11400000, guid: 07eb09616fff0de4a9eb04da0b4a7c13, type: 2}
    title: Pipe
    description: Extra jump height when jumping from the back half of the court.
    flavourText: '"Soar from deep."'
    sprite: {fileID: 21300000, guid: 3f7199b2abd337841954694949e6815c, type: 2}
  - myTechnique: {fileID: 11400000, guid: 080cd1d8669b77b44a54846f3826dcb7, type: 2}
    title: Sneak Strike
    description: Spike your own freeballs.
    flavourText: '"Attack when they least expect it."'
    sprite: {fileID: 21300000, guid: 38a1497787937e647bfbda14350d2947, type: 2}
  - myTechnique: {fileID: 11400000, guid: f159e9d19901e2d409e4a64438126ee5, type: 2}
    title: Agility
    description: Faster left-right movement speed.
    flavourText: '"Speed is the key!"'
    sprite: {fileID: 21300000, guid: 48040f8dee97c5c4cbd3eb54ba180510, type: 2}
  - myTechnique: {fileID: 11400000, guid: 8ae5d39d8e82f5541b99af03ad249400, type: 2}
    title: One-Two Punch
    description: Spiking on the second touch gives a burst of attack power.
    flavourText: '"Flow!"'
    sprite: {fileID: 21300000, guid: 0f1285869af3d3349a6b4284d44910aa, type: 2}
  - myTechnique: {fileID: 11400000, guid: 8cb172682f20b1e4fa417ffb26916100, type: 2}
    title: Lightning Quick
    description: Gain extra spike power when the ball is rising
    flavourText: “Hit before they can blink.”
    sprite: {fileID: 21300000, guid: c19ad58a5336f534e9ac9867aabe0057, type: 2}
  - myTechnique: {fileID: 11400000, guid: e462fd8aaf666324e9e7c4df3c5fa25c, type: 2}
    title: Hook tip
    description: Quick dropping tip
    flavourText: '"Drops like a rock."'
    sprite: {fileID: 21300000, guid: e74429b11cf832243b2eecb5283800ac, type: 2}
  - myTechnique: {fileID: 11400000, guid: 3fbed03724208334b962877dfe1b3df4, type: 2}
    title: Snake Eye Spike
    description: Falling backward? Spike hits harder.
    flavourText: “Bad position. Perfect angle.”
    sprite: {fileID: 21300000, guid: 28f92b328d0aa5b4f8b5f99f03af26f9, type: 2}
  - myTechnique: {fileID: 11400000, guid: 057cca485e91d9d47a34840967279b09, type: 2}
    title: Shutdown
    description: Move forward while blocking to instantly kill the ball.
    flavourText: “No mercy at the net.”
    sprite: {fileID: 21300000, guid: 9ebb47d0538c934449d4cf662c2954d5, type: 2}
  - myTechnique: {fileID: 11400000, guid: 8e4ec60fa55c9244d8125f9b83556f0b, type: 2}
    title: Heart Surge
    description: After the opponent scores, your next jumps are higher.
    flavourText: '"Bounce back!"'
    sprite: {fileID: 21300000, guid: 099bb7905d1c3f449b93721fb0c6a09b, type: 2}
  - myTechnique: {fileID: 11400000, guid: 46a76fff449f1764c85ccef5078c42c0, type: 2}
    title: Sky Serve
    description: Serve upward to create a plummeting sky ball.
    flavourText: '"What goes up..."'
    sprite: {fileID: 21300000, guid: 4b1032611a190cf4c9b9bd5dee9c6241, type: 2}
  - myTechnique: {fileID: 11400000, guid: aae05292462d27e46b3c1143346d5edf, type: 2}
    title: King Set
    description: When the setter is off-court, they’ll hurl fast, risky sets.
    flavourText: '"Jump. The ball will find you.”'
    sprite: {fileID: 21300000, guid: e969f1e1f97bcb74b81722fee4bbf8b3, type: 2}
  - myTechnique: {fileID: 11400000, guid: 267db09d8c9dcca449d77b95aeccbee4, type: 2}
    title: Guts
    description: On match point, you get a huge spike and jump boost.
    flavourText: “Comeback time!”
    sprite: {fileID: 21300000, guid: 2a027e3f5441cfc43ae1f163a941d134, type: 2}
  - myTechnique: {fileID: 11400000, guid: fe2f34cfaf3743a4ebf80ce53e16dc6d, type: 2}
    title: Dead Ball Set
    description: Setter throws precise, hanging quicks sets.
    flavourText: “Time freezes"
    sprite: {fileID: 21300000, guid: f7c39994dfae22546b03b97aa3969dab, type: 2}
  - myTechnique: {fileID: 11400000, guid: 2090d88aeb695304e964ff897cf02864, type: 2}
    title: Wild Form
    description: Occasionally, your spike will hit way harder. Unpredictable.
    flavourText: '"Hold nothing back."'
    sprite: {fileID: 21300000, guid: c54dc1b215b6a3745bede08f9946a82d, type: 2}
  - myTechnique: {fileID: 11400000, guid: 050da6d18f345b845b90ca60f3fd8867, type: 2}
    title: Anchor Bump
    description: Absorb more force on bump.
    flavourText: “Plant your feet.”
    sprite: {fileID: 21300000, guid: 6b2e7e384da7f554f9d60ba42a549ca3, type: 2}
  - myTechnique: {fileID: 11400000, guid: 0048ce832060bca4db0663123ed0f565, type: 2}
    title: Long Toss
    description: Tips are fast and low. Can bounce off blocks.
    flavourText: '“Half spike, half tip.” '
    sprite: {fileID: 21300000, guid: 3fd3064937ba32042a30a4535e820ed1, type: 2}
  - myTechnique: {fileID: 11400000, guid: c9178c3d24e5a364488c32baf2557993, type: 2}
    title: Knockout Serve
    description: Serve power multiplied.
    flavourText: '"Dont miss!"'
    sprite: {fileID: 21300000, guid: cd705a5407b169f47921844369df7c79, type: 2}
  - myTechnique: {fileID: 11400000, guid: f9d1eff6a37f80d44aaa43e60c7e83af, type: 2}
    title: Momentum Smash
    description: Spiking at high speed increases power.
    flavourText: '"Hesitation is defeat."'
    sprite: {fileID: 21300000, guid: 8a6d421e7ab3922479b113ba025c3ae0, type: 2}
  - myTechnique: {fileID: 11400000, guid: 76c2e2e57ebf40643810dafe24d3ce6d, type: 2}
